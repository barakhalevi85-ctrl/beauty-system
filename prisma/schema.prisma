datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model Client {
  id                       String         @id @default(uuid())
  name                     String
  lastName                 String?
  phone                    String
  email                    String?
  idNumber                 String?
  dateOfBirth              String?
  gender                   String?
  leadSource               String?
  address                  String?
  medicalNotes             String?
  healthDeclarationSent    Boolean        @default(false)
  healthDeclarationSigned  Boolean        @default(false)
  healthDeclarationFileUrl String?
  isActive                 Boolean        @default(true)
  createdAt                DateTime       @default(now())
  updatedAt                DateTime       @updatedAt
  treatmentLogs            TreatmentLog[]
  appointments             Appointment[]
  callLogs                 CallLog[]
  clientSeries             ClientSeries[]
}

model ClientSeries {
  id              String         @id @default(uuid())
  clientId        String
  client          Client         @relation(fields: [clientId], references: [id])
  serviceId       String?
  service         Service?       @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  serviceName     String?        // Historical name snapshot
  totalTreatments Int            // 1 for single treatment, X for series
  usedTreatments  Int            @default(0)
  pricePaid       Float?
  isCompleted     Boolean        @default(false)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  treatmentLogs   TreatmentLog[]
}

model TreatmentLog {
  id              String        @id @default(uuid())
  clientId        String
  client          Client        @relation(fields: [clientId], references: [id])
  clientSeriesId  String?
  clientSeries    ClientSeries? @relation(fields: [clientSeriesId], references: [id], onDelete: SetNull)
  treatmentNumber Int
  seriesTotal     Int?
  bodyArea        String
  fluenceJoule    Float
  technicianNotes String?
  imageUrls       String?
  createdAt       DateTime      @default(now())
}

model Appointment {
  id          String   @id @default(uuid())
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id])
  serviceId   String?
  service     Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  serviceName String?  // Historical name snapshot
  date        DateTime
  status      String
  createdAt   DateTime @default(now())
}

model Service {
  id              String         @id @default(uuid())
  category        String
  name            String
  packageType     String
  price           Float
  durationMinutes Int
  appointments    Appointment[]
  clientSeries    ClientSeries[]
}

model CallLog {
  id        String   @id @default(uuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id])
  notes     String
  createdAt DateTime @default(now())
}

model SystemSettings {
  id               String   @id @default("default")
  weeklySchedule   String   @default("{\"0\":{\"isOpen\":true,\"start\":\"08:00\",\"end\":\"20:00\"},\"1\":{\"isOpen\":true,\"start\":\"08:00\",\"end\":\"20:00\"},\"2\":{\"isOpen\":true,\"start\":\"08:00\",\"end\":\"20:00\"},\"3\":{\"isOpen\":true,\"start\":\"08:00\",\"end\":\"20:00\"},\"4\":{\"isOpen\":true,\"start\":\"08:00\",\"end\":\"20:00\"},\"5\":{\"isOpen\":true,\"start\":\"08:00\",\"end\":\"14:00\"},\"6\":{\"isOpen\":false,\"start\":\"08:00\",\"end\":\"20:00\"}}")
  businessSettings String?  // JSON string for logo, invoices, etc.
  messageSettings  String?  // JSON string for whatsapp/sms automations
  updatedAt        DateTime @updatedAt
}

model ClosedDate {
  id          String   @id @default(uuid())
  date        DateTime @unique
  description String?
  createdAt   DateTime @default(now())
}

model Employee {
  id          String   @id @default(uuid())
  name        String
  phone       String
  email       String?
  role        String?
  hourlyWage  Float?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  timeReports EmployeeTimeReport[]
  leaves      EmployeeLeave[]
}

model EmployeeTimeReport {
  id          String   @id @default(uuid())
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date        DateTime
  startTime   String   // "09:00"
  endTime     String   // "17:00"
  totalHours  Float?
  notes       String?
  createdAt   DateTime @default(now())
}

model EmployeeLeave {
  id          String   @id @default(uuid())
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date        DateTime
  type        String   // "VACATION", "SICK", "OTHER"
  notes       String?
  createdAt   DateTime @default(now())
}
