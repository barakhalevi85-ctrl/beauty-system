datasource db {
  provider = "sqlite"
  url      = "file:./dev2.db"
}

generator client {
  provider = "prisma-client-js"
}

model Business {
  id                 String   @id @default(uuid())
  name               String
  ownerId            String?  // Reference to the main Employee/Owner
  subscriptionStatus String   @default("TRIAL") // TRIAL, ACTIVE, SUSPENDED
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  clients         Client[]
  employees       Employee[]
  services        Service[]
  appointments    Appointment[]
  treatmentLogs   TreatmentLog[]
  invoices        Invoice[]
  clientSeries    ClientSeries[]
  callLogs        CallLog[]
  closedDates     ClosedDate[]
  systemSettings  SystemSettings?
}

model Client {
  id                       String         @id @default(uuid())
  businessId               String
  business                 Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  
  name                     String
  lastName                 String?
  phone                    String
  email                    String?
  idNumber                 String?
  dateOfBirth              String?
  gender                   String?
  leadSource               String?
  address                  String?
  medicalNotes             String?
  healthDeclarationSent    Boolean        @default(false)
  healthDeclarationSigned  Boolean        @default(false)
  healthDeclarationFileUrl String?
  isActive                 Boolean        @default(true)
  createdAt                DateTime       @default(now())
  updatedAt                DateTime       @updatedAt
  
  treatmentLogs            TreatmentLog[]
  appointments             Appointment[]
  callLogs                 CallLog[]
  clientSeries             ClientSeries[]
  invoices                 Invoice[]
}

model ClientSeries {
  id              String         @id @default(uuid())
  businessId      String
  business        Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  clientId        String
  client          Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  serviceId       String?
  service         Service?       @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  serviceName     String?
  totalTreatments Int
  usedTreatments  Int            @default(0)
  pricePaid       Float?
  isCompleted     Boolean        @default(false)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  treatmentLogs   TreatmentLog[]
  invoices        Invoice[]
}

model TreatmentLog {
  id              String        @id @default(uuid())
  businessId      String
  business        Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  clientId        String
  client          Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientSeriesId  String?
  clientSeries    ClientSeries? @relation(fields: [clientSeriesId], references: [id], onDelete: SetNull)
  appointmentId   String?       @unique
  appointment     Appointment?  @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  treatmentNumber Int
  seriesTotal     Int?
  bodyArea        String
  fluenceJoule    Float
  technicianNotes String?
  imageUrls       String?
  createdAt       DateTime      @default(now())
  invoices        Invoice[]
}

model Appointment {
  id           String        @id @default(uuid())
  businessId   String
  business     Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  clientId     String
  client       Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  serviceId    String?
  service      Service?      @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  serviceName  String?
  date         DateTime
  status       String
  treatmentLog TreatmentLog?
  createdAt    DateTime      @default(now())
}

model Service {
  id              String         @id @default(uuid())
  businessId      String
  business        Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  category        String
  name            String
  packageType     String
  price           Float
  durationMinutes Int
  appointments    Appointment[]
  clientSeries    ClientSeries[]
}

model CallLog {
  id         String   @id @default(uuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  clientId   String
  client     Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  notes      String
  createdAt  DateTime @default(now())
}

model SystemSettings {
  id               String   @id @default(uuid())
  businessId       String   @unique
  business         Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  weeklySchedule   String   @default("{\"0\":{\"isOpen\":true,\"start\":\"08:00\",\"end\":\"20:00\"},\"1\":{\"isOpen\":true,\"start\":\"08:00\",\"end\":\"20:00\"},\"2\":{\"isOpen\":true,\"start\":\"08:00\",\"end\":\"20:00\"},\"3\":{\"isOpen\":true,\"start\":\"08:00\",\"end\":\"20:00\"},\"4\":{\"isOpen\":true,\"start\":\"08:00\",\"end\":\"20:00\"},\"5\":{\"isOpen\":true,\"start\":\"08:00\",\"end\":\"14:00\"},\"6\":{\"isOpen\":false,\"start\":\"08:00\",\"end\":\"20:00\"}}")
  businessSettings String?
  messageSettings  String?
  updatedAt        DateTime @updatedAt
}

model ClosedDate {
  id          String   @id @default(uuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  date        DateTime // No longer globally unique, multiple businesses can close on same date
  description String?
  createdAt   DateTime @default(now())
}

model Employee {
  id          String   @id @default(uuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name        String
  phone       String
  email       String?
  role        String?  // SUPER_ADMIN for platform owner, ADMIN for salon owner, EMPLOYEE for workers
  hourlyWage  Float?
  username    String?  @unique
  password    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  timeReports EmployeeTimeReport[]
  leaves      EmployeeLeave[]
}

model EmployeeTimeReport {
  id          String   @id @default(uuid())
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date        DateTime
  startTime   String
  endTime     String
  totalHours  Float?
  notes       String?
  createdAt   DateTime @default(now())
}

model EmployeeLeave {
  id          String   @id @default(uuid())
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date        DateTime
  type        String
  notes       String?
  createdAt   DateTime @default(now())
}

model Invoice {
  id             String        @id @default(uuid())
  businessId     String
  business       Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  invoiceNumber  String        // Now string to support prefixes per business if needed
  clientId       String
  client         Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  amount         Float
  type           String
  paymentMethod  String?
  date           DateTime      @default(now())
  description    String
  items          String?
  treatmentLogId String?
  treatmentLog   TreatmentLog? @relation(fields: [treatmentLogId], references: [id], onDelete: SetNull)
  clientSeriesId String?
  clientSeries   ClientSeries? @relation(fields: [clientSeriesId], references: [id], onDelete: SetNull)
  createdAt      DateTime      @default(now())
}
